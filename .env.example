# ── Kobo ──────────────────────────────────────────────────────────────────────
KOBO_TOKEN=your-kobo-api-token-here
FORM_UID=your-form-uid-here
KOBO_BASE_URL=https://kf.kobotoolbox.org
KOBO_WEBHOOK_SECRET=your-webhook-secret-here

# ── BigQuery ───────────────────────────────────────────────────────────────────
BQ_PROJECT=your-gcp-project-id
BQ_DATASET=kobo_data
BQ_TABLE=kobo_post_survey

# ── Google Sheets ──────────────────────────────────────────────────────────────
SHEET_ID=
SHEET_NAME=Kobo Pipeline Data
SHEET_TAB=Survey Data
SHARED_DRIVE_FOLDER_ID=
TEAM_EMAILS=alice@org.org,bob@org.org

# ── New entry notification (fires on every new submission) ─────────────────────
NEW_ENTRY_NOTIFY_EMAILS=lead@org.org,manager@org.org

# ── Pipeline config ────────────────────────────────────────────────────────────
SYNC_MODE=append
MAX_SHEET_ROWS=10000
TEST_KEYWORDS=test,testing,demo,sample,dummy
ALERT_EMAILS=admin@org.org

# ── GCP auth (production) ──────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
