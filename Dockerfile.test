FROM --platform=linux/amd64 python:3.11-slim

WORKDIR /app

# Copy everything needed for tests
COPY shared/           /app/shared/
COPY services/         /app/services/
COPY tests/            /app/tests/

# Copy all requirements files
COPY shared/requirements.txt         shared_reqs.txt
COPY services/webhook/requirements.txt webhook_reqs.txt
COPY services/sync/requirements.txt   sync_reqs.txt
COPY requirements-dev.txt             requirements-dev.txt

# Install all dependencies in one layer to avoid caching issues
RUN pip install --no-cache-dir \
    -r shared_reqs.txt \
    -r webhook_reqs.txt \
    -r sync_reqs.txt \
    -r requirements-dev.txt \
    fastapi \
    uvicorn \
    python-multipart \
    responses>=0.23.0

ENV PYTHONPATH=/app/shared:/app/services/webhook:/app/services/sync

# Run tests
CMD ["pytest", "tests/", "-v", \
     "--cov=shared", \
     "--cov=services", \
     "--cov-report=term-missing", \
     "--cov-fail-under=80"]
