FROM --platform=linux/amd64 python:3.11-slim

WORKDIR /app

# Copy everything needed for tests
COPY shared/           /app/shared/
COPY services/         /app/services/
COPY tests/            /app/tests/
COPY shared/requirements.txt shared_reqs.txt
COPY services/webhook/requirements.txt webhook_reqs.txt
COPY services/sync/requirements.txt sync_reqs.txt

# Install all dependencies
RUN pip install --no-cache-dir -r shared_reqs.txt
RUN pip install --no-cache-dir -r webhook_reqs.txt
RUN pip install --no-cache-dir -r sync_reqs.txt
RUN pip install --no-cache-dir fastapi uvicorn python-multipart

# Install test dependencies
COPY requirements-dev.txt .
RUN pip install --no-cache-dir -r requirements-dev.txt

ENV PYTHONPATH=/app/shared:/app/services/webhook:/app/services/sync

# Run tests
CMD ["pytest", "tests/", "-v", "--cov=shared", "--cov=services", \
     "--cov-report=term-missing", "--cov-fail-under=80"]